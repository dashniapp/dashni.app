{
  "expo": {
    "name": "Dashni",
    "slug": "dashni-albanian-dating",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e91e8c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dashni",
      "infoPlist": {
        "NSCameraUsageDescription": "Dashni uses your camera to take profile photos and record profile videos.",
        "NSMicrophoneUsageDescription": "Dashni uses your microphone for profile video recording.",
        "NSPhotoLibraryUsageDescription": "Dashni accesses your photo library so you can upload profile photos.",
        "NSUserNotificationsUsageDescription": "Dashni sends notifications when you receive new matches and messages.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e91e8c"
      },
      "package": "com.dashni",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "6f2c4b8c-4069-49bf-aa23-f6603cf1e4ea"
      }
    },
    "owner": "bjeshkan1"
  }
}
